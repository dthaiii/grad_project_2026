# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── Event Producer ─────────────────────────────────────────────────────────────
EVENTS_PER_SECOND=10
NUM_USERS=1000
NUM_SONGS=500

# ── Spark ──────────────────────────────────────────────────────────────────────
SPARK_MASTER=spark://spark-master:7077

# ── Data Lake ──────────────────────────────────────────────────────────────────
DATALAKE_PATH=/data/lake
CHECKPOINT_PATH=/data/checkpoints
ANALYTICS_PATH=/data/lake/analytics

# ── Streaming Trigger ──────────────────────────────────────────────────────────
TRIGGER_INTERVAL=2 minutes

# ── Batch Schedule ─────────────────────────────────────────────────────────────
BATCH_INTERVAL_SECONDS=3600
